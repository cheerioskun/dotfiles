#!/usr/bin/env bash
set -euo pipefail

log() { printf '[dotfiles] %s\n' "$*"; }

skill_packages=(
  cheerioskun/explainer
  cheerioskun/gatech-advisor
  cheerioskun/wayfarer
)

if ! command -v npx >/dev/null 2>&1; then
  log "skipping skill install: npx is not available"
  exit 0
fi

for package in "${skill_packages[@]}"; do
  log "installing skill package: $package"
  npx --yes skills add "$package"
done
