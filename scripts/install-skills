#!/usr/bin/env bash
set -euo pipefail

log() { printf '[dotfiles] %s\n' "$*"; }

SKILLS_INSTALL_DIR="${SKILLS_INSTALL_DIR:-$HOME}"

skill_installs=(
  "https://github.com/cheerioskun/skills --skill explainer"
  "https://github.com/cheerioskun/skills --skill gatech-advisor"
  "https://github.com/cheerioskun/skills --skill wayfarer"
)

if ! command -v npx >/dev/null 2>&1; then
  log "skipping skill install: npx is not available"
  exit 0
fi

log "installing skills from directory: $SKILLS_INSTALL_DIR"

for install in "${skill_installs[@]}"; do
  read -r -a args <<< "$install"
  log "installing skill: $install"
  (
    cd "$SKILLS_INSTALL_DIR"
    npx --yes skills add "${args[@]}" --yes
  )
done
